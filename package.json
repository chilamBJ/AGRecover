{
  "name": "ag-recover",
  "displayName": "AG Recover",
  "description": "Antigravity 聊天记录实时备份 & 一键恢复",
  "version": "0.2.0",
  "publisher": "ag-recover",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      { "command": "agRecover.forceSync", "title": "AG Recover: Force Sync Now", "icon": "$(sync)" },
      { "command": "agRecover.restore", "title": "AG Recover: Restore All (L1 批量恢复)" },
      { "command": "agRecover.inject", "title": "AG Recover: Inject to AG History (选择性注入)" },
      { "command": "agRecover.export", "title": "AG Recover: Export Conversation to Markdown" },
      { "command": "agRecover.search", "title": "AG Recover: Search Conversations" },
      { "command": "agRecover.openBackupFolder", "title": "AG Recover: Open Backup Folder" },
      { "command": "agRecover.showStatus", "title": "AG Recover: Show Sync Status" },
      { "command": "agRecover.refreshTree", "title": "Refresh", "icon": "$(refresh)" }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agRecover",
          "title": "AG Recover",
          "icon": "$(history)"
        }
      ]
    },
    "views": {
      "agRecover": [
        {
          "id": "agRecoverConversations",
          "name": "Conversations",
          "type": "tree"
        }
      ]
    },
    "menus": {
      "view/title": [
        { "command": "agRecover.refreshTree", "when": "view == agRecoverConversations", "group": "navigation" },
        { "command": "agRecover.forceSync", "when": "view == agRecoverConversations", "group": "navigation" }
      ],
      "view/item/context": [
        { "command": "agRecover.export", "when": "view == agRecoverConversations && viewItem == conversationWithMd" }
      ]
    },
    "configuration": {
      "title": "AG Recover",
      "properties": {
        "agRecover.backupDir": {
          "type": "string",
          "default": "",
          "description": "备份根目录（留空使用默认 ~/.ag-recover）"
        },
        "agRecover.autoBackup": {
          "type": "boolean",
          "default": true,
          "description": "启用自动备份"
        },
        "agRecover.gitAutoCommit": {
          "type": "boolean",
          "default": false,
          "description": "启用 git 自动 commit"
        },
        "agRecover.gitScope": {
          "type": "array",
          "default": ["conversations_md", "brain"],
          "items": { "type": "string" },
          "description": "git commit 涵盖的目录"
        },
        "agRecover.mdSyncIntervalSeconds": {
          "type": "number",
          "default": 60,
          "description": "L2 MD 备份最小间隔（秒）"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "sql.js": "^1.10.0"
  }
}
